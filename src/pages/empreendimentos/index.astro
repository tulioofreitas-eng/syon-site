---
import Layout from '../../layouts/Layout.astro';
---
<Layout
  title="Empreendimentos — Syon Incorporações"
  description="Conheça os empreendimentos residenciais e comerciais da Syon Incorporações."
  active="empreendimentos"
>

<section class="page-header">
  <div class="wrap">
    <span class="eyebrow">Empreendimentos</span>
    <h1>Cada projeto, construído por dentro.</h1>
    <p>Do terreno à entrega, com engenharia e execução do próprio grupo.</p>
  </div>
</section>

<section class="empreendimentos-section" style="background:var(--branco); padding-top:90px;">
  <div class="wrap">
    <div class="empreendimentos-grid">
      <div class="empreendimento-card">
        <div class="imagem">
          <svg viewBox="0 0 100 100" fill="none" stroke="#fff" stroke-width="1"><rect x="30" y="10" width="40" height="80"/><line x1="30" y1="25" x2="70" y2="25"/><line x1="30" y1="40" x2="70" y2="40"/><line x1="30" y1="55" x2="70" y2="55"/><line x1="30" y1="70" x2="70" y2="70"/></svg>
        </div>
        <div class="conteudo">
          <span class="local">Balneário Camboriú, SC</span>
          <h3>Projeto Alvin</h3>
          <p>Torre residencial e comercial de alto padrão — em desenvolvimento.</p>
          <a href="/empreendimentos/alvin" class="btn btn-outline">Ver empreendimento</a>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>
